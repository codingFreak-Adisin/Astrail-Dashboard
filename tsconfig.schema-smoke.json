    "incremental": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".tmp/schema-validation-smoke",
    "target": "ES2022",
    "tsBuildInfoFile": ".tmp/schema-validation-smoke.tsbuildinfo"
